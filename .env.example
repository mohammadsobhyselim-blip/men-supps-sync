# Shopify
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_API_VERSION=2025-01

# MFsupps (WooCommerce REST API)
MFSUPPS_API_URL=https://mfsupps.com
MFSUPPS_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MFSUPPS_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MyFitnessBag (WooCommerce REST API)
FITNESSBAG_API_URL=https://myfitnessbag.com
FITNESSBAG_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FITNESSBAG_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sync settings
SYNC_INTERVAL_HOURS=6
LOG_LEVEL=INFO
